generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  uid           String    @unique
  email         String    @unique
  emailVerified Boolean   @default(false)
  displayName   String?
  photoURL      String?
  role          String    @default("VIEWER")
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  profile       Profile?
  scholarships  Scholarship[] @relation("UserScholarships")
  favorites     Favorite[]
  verifiedScholarships Scholarship[] @relation("VerifiedScholarships")
  subscription  Subscription?
  transactions  Transaction[]
  documents     Document[]
  universityMatches UniversityMatch[]
  outreachCandidates OutreachCandidate[]
  deadlines     Deadline[]    // NEW

  @@index([uid])
  @@index([email])
  @@index([deletedAt])
  @@index([role])
}

model Profile {
  id                String    @id @default(cuid())
  userId            String    @unique
  firstName         String?
  lastName          String?
  dateOfBirth       DateTime?
  nationality       String?
  countryOfResidence String?
  educationLevel    String?
  gpa               Float?
  fieldsOfInterest  String[]
  targetCountries   String[]
  budgetRange       Json?
  fieldOfStudy      String?
  targetFields      String[]
  scholarshipTypes  String[]
  skills            String[]
  languages         String[]
  achievements      String[]
  volunteerWork     Json?
  careerGoal        String?
  interests         String[]
  researchAreas     String[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Scholarship {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.Text
  provider          String
  providerType      String
  scholarshipType   String
  country           String?
  continent         String?
  universityCountry String?
  eligibilityRules  Json?
  targetFields      String[]
  targetNationalities String[]
  targetCountries   String[]
  educationLevels   String[]
  amountMin         Int?
  amountMax         Int?
  amountCurrency    String    @default("USD")
  applicationDeadline DateTime?
  decisionDate      DateTime?
  notificationDate  DateTime?
  applicationURL    String?
  applicationFee    Int?
  requiredDocuments String[]
  essayPrompt       String?   @db.Text
  requirements      Json?
  tags              String[]
  isVerified        Boolean   @default(false)
  lastVerifiedAt    DateTime?
  verifiedBy        String?
  verifiedByUser    User?     @relation("VerifiedScholarships", fields: [verifiedBy], references: [id])
  source            String
  viewCount         Int       @default(0)
  matchCount        Int       @default(0)
  createdBy         String?
  createdByUser     User?     @relation("UserScholarships", fields: [createdBy], references: [id])
  favoritedBy       Favorite[]
  recentlyPosted    Boolean   @default(false)
  images            Image[]
  documents         Document[]
  deadlines         Deadline[]  // ✅ ADD THIS

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([provider])
  @@index([applicationDeadline])
  @@index([scholarshipType])
  @@index([isVerified])
  @@index([deletedAt])
  @@index([tags])
  @@index([country])
  @@index([continent])
  @@index([universityCountry])
}
model Favorite {
  id              String    @id @default(cuid())
  userId          String
  scholarshipId   String
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarship     Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([userId, scholarshipId])
  @@index([userId])
  @@index([scholarshipId])
}

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planType          PlanType  @default(FREE)
  planFeatures      Json?
  status            SubscriptionStatus @default(ACTIVE)
  amount            Int?
  currency          String    @default("USD")
  interval          String?
  trialEndsAt       DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt        DateTime?
  pausedAt          DateTime?
  stripeSubscriptionId String? @unique
  stripeCustomerId    String?
  chapaTransactionId  String?  @unique
  chapaPaymentId      String?  @unique
  chapaCheckoutUrl    String?
  cancellationReason String?
  retentionAttempts  Int       @default(0)
  transactions      Transaction[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([userId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([planType])
}

enum PlanType {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
  TRIAL
  EXPIRED
}

model Transaction {
  id                String    @id @default(cuid())
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])
  subscriptionId    String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  amountUSD         Int?
  amountETB         Int?
  exchangeRate      Float?
  provider          PaymentProvider
  providerTransactionId String?
  providerStatus    String?
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  idempotencyKey    String    @unique
  metadata          Json?
  failureReason     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([provider])
  @@index([providerTransactionId])
  @@index([idempotencyKey])
}

enum PaymentProvider {
  STRIPE
  CHAPA
}

enum TransactionType {
  SUBSCRIPTION_CREATE
  SUBSCRIPTION_RENEW
  SUBSCRIPTION_UPGRADE
  SUBSCRIPTION_DOWNGRADE
  REFUND
  PAYMENT_FAILURE
  RETRY
  MANUAL
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

// ============ UNIVERSITY MODELS ============

model University {
  id                String    @id @default(cuid())
  name              String
  shortName         String?
  description       String?   @db.Text
  website           String?
  address           String?
  country           String
  city              String
  postalCode        String?
  latitude          Float?
  longitude         Float?
  foundedYear       Int?
  publicPrivate     PublicPrivate?
  enrollment        Int?
  internationalRate Float?
  acceptanceRate    Float?
  ranking           Int?
  admissionsEmail   String?
  admissionsPhone   String?
  internationalOffice String?
  avgTuitionLocal   Int?
  avgTuitionInternational Int?
  avgLivingCosts    Int?
  programs          Program[]
  images            Image[]
  tags              String[]
  isVerified        Boolean   @default(false)
  lastVerifiedAt    DateTime?
  source            String
  viewCount         Int       @default(0)
  matches           UniversityMatch[]
  outreachCampaigns OutreachCampaign[]
  documents         Document[]
  deadlines         Deadline[]  // ✅ ADD THIS

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([name])
  @@index([country])
  @@index([city])
  @@index([latitude, longitude])
  @@index([deletedAt])
}

enum PublicPrivate {
  PUBLIC
  PRIVATE
  OTHER
}

model Program {
  id                String    @id @default(cuid())
  universityId      String
  university        University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  name              String
  degreeLevel       DegreeLevel
  field             String
  specialization    String?
  durationMonths    Int?
  language          String    @default("English")
  admissionRequirements Json?
  tuitionLocal      Int?
  tuitionInternational Int?
  hasScholarships   Boolean   @default(false)
  applicationDeadline DateTime?
  startDate         DateTime?
  endDate           DateTime?
  isActive          Boolean   @default(true)
  lastVerifiedAt    DateTime?
  matches           UniversityMatch[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([universityId])
  @@index([field])
  @@index([degreeLevel])
}

enum DegreeLevel {
  BACHELORS
  MASTERS
  PHD
  CERTIFICATE
  ASSOCIATE
  OTHER
}

model UniversityMatch {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  universityId      String
  university        University @relation(fields: [universityId], references: [id])
  programId         String?
  program           Program?   @relation(fields: [programId], references: [id])
  admissionProbability Float
  probabilityRange  Json?
  confidence        Float
  fitScore          Float
  financialFit      Float?
  scoreBreakdown    Json?
  methodology       String    @default("RULE_BASED")
  positiveFactors   String[]
  improvementAreas  String[]
  summary           String?   @db.Text
  matchType         String    @default("UNIVERSITY")
  status            String    @default("PENDING")
  version           String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([universityId])
  @@index([admissionProbability])
  @@index([status])
}

model Image {
  id              String    @id @default(cuid())
  universityId    String?
  university      University? @relation(fields: [universityId], references: [id])
  scholarshipId   String?
  scholarship     Scholarship? @relation(fields: [scholarshipId], references: [id])
  url             String
  thumbnailUrl    String?
  mediumUrl       String?
  largeUrl        String?
  source          ImageSource
  sourceId        String?
  attribution     Json?
  alt             String?
  caption         String?
  width           Int?
  height          Int?
  fileSize        Int?
  isVerified      Boolean   @default(false)
  verificationNote String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([universityId])
  @@index([scholarshipId])
  @@index([source])
  @@index([isVerified])
}

enum ImageSource {
  MAPBOX
  WIKIMEDIA
  UNSPLASH
  ADMIN_UPLOAD
  USER_UPLOAD
}

model OutreachCampaign {
  id                String    @id @default(cuid())
  universityId      String
  university        University @relation(fields: [universityId], references: [id])
  name              String
  description       String?
  status            String    @default("DRAFT")
  targetCriteria    Json?
  emailTemplate     String?   @db.Text
  tone              String    @default("FORMAL")
  branding          Json?
  candidates        OutreachCandidate[]
  sentCount         Int       @default(0)
  openedCount       Int       @default(0)
  repliedCount      Int       @default(0)
  convertedCount    Int       @default(0)
  createdBy         String
  approvedBy        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([universityId])
  @@index([status])
  @@index([createdAt])
}

model OutreachCandidate {
  id                String    @id @default(cuid())
  campaignId        String
  campaign          OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  consentProvided   Boolean   @default(false)
  consentGivenAt    DateTime?
  consentVersion    String?
  status            String    @default("PENDING")
  emailSentAt       DateTime?
  emailOpenedAt     DateTime?
  emailRepliedAt    DateTime?
  conversionStatus  String    @default("NOT_CONVERTED")
  matchScore        Float?
  matchExplanation  String?   @db.Text
  matchVersion      String?
  generatedEmail    String?   @db.Text
  personalization   Json?
  notes             String?   @db.Text
  tags              String[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@index([consentProvided])
  @@index([matchScore])
}

// ============ DOCUMENT MODELS ============

model Document {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  type            DocumentType
  description     String?
  promptVersion   String?
  aiModel         String?
  currentVersionId String?
  versions        DocumentVersion[]
  wordCount       Int?
  language        String    @default("English")
  isGenerated     Boolean   @default(true)
  isEdited        Boolean   @default(false)
  scholarshipId   String?
  scholarship     Scholarship? @relation(fields: [scholarshipId], references: [id])
  universityId    String?
  university      University? @relation(fields: [universityId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([userId])
  @@index([type])
  @@index([scholarshipId])
  @@index([deletedAt])
}

enum DocumentType {
  CV
  SOP
  MOTIVATION_LETTER
  ESSAY
  RECOMMENDATION_EMAIL
  APPLICATION_EMAIL
  OUTREACH_EMAIL
  OTHER
}

model DocumentVersion {
  id              String    @id @default(cuid())
  documentId      String
  document        Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content         String    @db.Text
  contentDelta    Json?
  wordCount       Int?
  generationPrompt String?   @db.Text
  generationParams Json?
  aiScore         Float?
  userRating      Int?
  versionNumber   Int
  isCurrent       Boolean   @default(false)
  changeDescription String?
  createdAt       DateTime  @default(now())

  @@index([documentId])
  @@index([versionNumber])
  @@index([isCurrent])
}

// ============ DEADLINE MODELS ============

model Deadline {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Context
  title             String
  description       String?
  type              DeadlineType
  
  // Timing
  dueDate           DateTime
  dueTimezone       String    @default("UTC")
  reminderOffset    Int?      // Minutes before due date
  isCompleted       Boolean   @default(false)
  completedAt       DateTime?
  
  // Related Entity
  scholarshipId     String?
  scholarship       Scholarship? @relation(fields: [scholarshipId], references: [id])
  universityId      String?
  university        University? @relation(fields: [universityId], references: [id])
  
  // Reminders
  reminders         Reminder[]
  
  // Metadata
  priority          Priority  @default(MEDIUM)
  notes             String?   @db.Text
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([userId])
  @@index([dueDate])
  @@index([type])
  @@index([isCompleted])
  @@index([userId, dueDate])
}

enum DeadlineType {
  APPLICATION
  SCHOLARSHIP
  ADMISSION
  DOCUMENT
  INTERVIEW
  TEST
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Reminder {
  id                String    @id @default(cuid())
  deadlineId        String
  deadline          Deadline  @relation(fields: [deadlineId], references: [id], onDelete: Cascade)
  
  // Schedule
  scheduledAt       DateTime
  sentAt            DateTime?
  
  // Content
  channel           Channel
  status            ReminderStatus @default(PENDING)
  
  // Metadata
  attempts          Int       @default(0)
  errorMessage      String?
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([deadlineId])
  @@index([scheduledAt])
  @@index([status])
}

enum Channel {
  EMAIL
  IN_APP
  PUSH
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}