generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User table - stores all user accounts
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  displayName   String?
  photoURL      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relationships
  profile       Profile?

  @@index([email])
  @@index([deletedAt])
}

// Profile table - stores user profile information
model Profile {
  id                String    @id @default(cuid())
  userId            String    @unique
  firstName         String?
  lastName          String?
  dateOfBirth       DateTime?
  nationality       String?
  countryOfResidence String?
  educationLevel    String?   // HIGH_SCHOOL, BACHELORS, MASTERS, PHD
  gpa               Float?
  fieldsOfInterest  String[]  // ["Computer Science", "Data Science"]
  targetCountries   String[]
  budgetRange       Json?     // { min: 0, max: 50000, currency: "USD" }
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationship - Fixed!
  user              User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

// Scholarship table - stores scholarship opportunities
model Scholarship {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.Text
  provider          String
  providerType      String    // UNIVERSITY, GOVERNMENT, PRIVATE, NGO, OTHER
  
  // Eligibility
  eligibilityRules  Json?     // { gpaMin: 3.0, nationality: ["US"], educationLevel: ["BACHELORS"] }
  targetFields      String[]  // ["Computer Science", "Engineering"]
  targetNationalities String[]
  targetCountries   String[]
  educationLevels   String[]  // HIGH_SCHOOL, BACHELORS, MASTERS, PHD
  
  // Financial
  amountMin         Int?      // in cents USD
  amountMax         Int?      // in cents USD
  amountCurrency    String    @default("USD")
  scholarshipType   String    // FULL, PARTIAL, MERIT_BASED, NEED_BASED, RESEARCH, DIVERSITY
  
  // Deadlines
  applicationDeadline DateTime?
  decisionDate      DateTime?
  notificationDate  DateTime?
  
  // Application
  applicationURL    String?
  applicationFee    Int?      // in cents USD
  requiredDocuments String[] // ["Transcript", "CV", "SOP", "Recommendation Letters"]
  essayPrompt       String?   @db.Text
  
  // Metadata
  tags              String[]
  isVerified        Boolean   @default(false)
  lastVerifiedAt    DateTime?
  source            String    // "API_IMPORT", "ADMIN_CREATED", "USER_SUBMITTED"
  viewCount         Int       @default(0)
  matchCount        Int       @default(0)
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Indexes for faster queries
  @@index([provider])
  @@index([applicationDeadline])
  @@index([scholarshipType])
  @@index([isVerified])
  @@index([deletedAt])
  @@index([tags]) // For search
}