generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  uid           String    @unique
  email         String    @unique
  emailVerified Boolean   @default(false)
  displayName   String?
  photoURL      String?
  role          String    @default("VIEWER")
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  profile       Profile?
  scholarships  Scholarship[] @relation("UserScholarships")
  favorites     Favorite[]
  verifiedScholarships Scholarship[] @relation("VerifiedScholarships")
  subscription  Subscription?
  transactions  Transaction[]
  documents     Document[]    // NEW

  @@index([uid])
  @@index([email])
  @@index([deletedAt])
  @@index([role])
}

model University {
  id                String    @id @default(cuid())
  name              String
  shortName         String?
  description       String?   @db.Text
  website           String?
  address           String?
  country           String
  city              String
  postalCode        String?
  latitude          Float?
  longitude         Float?
  
  // Academic
  foundedYear       Int?
  publicPrivate     PublicPrivate?
  enrollment        Int?
  internationalRate Float?    // % of international students
  acceptanceRate    Float?    // 0.0-1.0
  ranking           Int?
  
  // Contact
  admissionsEmail   String?
  admissionsPhone   String?
  internationalOffice String?
  
  // Financial
  avgTuitionLocal   Int?      // per year in cents USD
  avgTuitionInternational Int?
  avgLivingCosts    Int?
  
  // Content
  programs          Program[]
  images            Image[]
  
  // Metadata
  tags              String[]
  isVerified        Boolean   @default(false)
  lastVerifiedAt    DateTime?
  source            String
  viewCount         Int       @default(0)
  
  // Relationships
  matches           UniversityMatch[]
  outreachCampaigns OutreachCampaign[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([name])
  @@index([country])
  @@index([city])
  @@index([latitude, longitude])
  @@index([deletedAt])
}

enum PublicPrivate {
  PUBLIC
  PRIVATE
  OTHER
}

model Program {
  id                String    @id @default(cuid())
  universityId      String
  university        University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  name              String
  degreeLevel       DegreeLevel
  field             String
  specialization    String?
  
  // Academic
  durationMonths    Int?
  language          String    @default("English")
  admissionRequirements Json?  // { gpa: 3.0, tests: ["TOEFL"], prerequisites: [] }
  
  // Financial
  tuitionLocal      Int?      // per year
  tuitionInternational Int?
  hasScholarships   Boolean   @default(false)
  
  // Deadlines
  applicationDeadline DateTime?
  startDate         DateTime?
  endDate           DateTime?
  
  // Metadata
  isActive          Boolean   @default(true)
  lastVerifiedAt    DateTime?
  
  // Relationships
  matches           UniversityMatch[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([universityId])
  @@index([field])
  @@index([degreeLevel])
}

enum DegreeLevel {
  BACHELORS
  MASTERS
  PHD
  CERTIFICATE
  ASSOCIATE
  OTHER
}

model UniversityMatch {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  universityId      String
  university        University @relation(fields: [universityId], references: [id])
  programId         String?
  program           Program?   @relation(fields: [programId], references: [id])
  
  // Scoring
  admissionProbability Float   // 0.0-1.0
  probabilityRange  Json?     // { lower: 0.6, upper: 0.8 }
  confidence        Float
  fitScore          Float
  financialFit      Float?
  
  // Breakdown
  scoreBreakdown    Json?     // { academics: 0.8, extracurriculars: 0.7, essays: 0.6 }
  methodology       String    // "RULE_BASED", "ML_MODEL", "AI_GENERATED"
  
  // Explanations
  positiveFactors   String[]
  improvementAreas  String[]
  summary           String?   @db.Text
  
  // Metadata
  matchType         String    @default("UNIVERSITY")
  status            String    @default("PENDING")
  version           String
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([universityId])
  @@index([admissionProbability])
  @@index([status])
}

model Image {
  id              String    @id @default(cuid())
  
  // Reference
  universityId    String?
  university      University? @relation(fields: [universityId], references: [id])
  scholarshipId   String?
  scholarship     Scholarship? @relation(fields: [scholarshipId], references: [id])
  
  // Image Data
  url             String    // CDN URL
  thumbnailUrl    String?   // Small version
  mediumUrl       String?   // Medium version
  largeUrl        String?   // Large version
  
  // Attribution (required for Unsplash/Wikimedia)
  source          ImageSource
  sourceId        String?   // Original ID from source
  attribution     Json?     // { photographer: "Name", license: "CC0", link: "url" }
  
  // Metadata
  alt             String?
  caption         String?
  width           Int?
  height          Int?
  fileSize        Int?      // In bytes
  
  // Quality
  isVerified      Boolean   @default(false)
  verificationNote String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([universityId])
  @@index([scholarshipId])
  @@index([source])
  @@index([isVerified])
}

enum ImageSource {
  MAPBOX
  WIKIMEDIA
  UNSPLASH
  ADMIN_UPLOAD
  USER_UPLOAD
}

model Document {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Document Info
  title           String
  type            DocumentType
  description     String?
  
  // Generation
  promptVersion   String?   // Version of prompt used
  aiModel         String?   // "gemini-pro", "gemini-flash"
  
  // Content Storage
  currentVersionId String?
  versions        DocumentVersion[]
  
  // Metadata
  wordCount       Int?
  language        String    @default("English")
  isGenerated     Boolean   @default(true)
  isEdited        Boolean   @default(false)
  
  // Application Context
  scholarshipId   String?
  scholarship     Scholarship? @relation(fields: [scholarshipId], references: [id])
  universityId    String?
  university      University? @relation(fields: [universityId], references: [id])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([userId])
  @@index([type])
  @@index([scholarshipId])
  @@index([deletedAt])
}

enum DocumentType {
  CV
  SOP
  MOTIVATION_LETTER
  ESSAY
  RECOMMENDATION_EMAIL
  APPLICATION_EMAIL
  OUTREACH_EMAIL
  OTHER
}

model DocumentVersion {
  id              String    @id @default(cuid())
  documentId      String
  document        Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  // Content
  content         String    @db.Text
  contentDelta    Json?     // For diff tracking
  wordCount       Int?
  
  // Generation Context
  generationPrompt String?   @db.Text // The actual prompt used
  generationParams Json?     // { temperature, maxTokens, etc. }
  
  // Quality
  aiScore         Float?    // Self-assessment of quality
  userRating      Int?      // 1-5
  
  // Metadata
  versionNumber   Int
  isCurrent       Boolean   @default(false)
  changeDescription String?
  
  createdAt       DateTime  @default(now())

  @@index([documentId])
  @@index([versionNumber])
  @@index([isCurrent])
}

model Profile {
  id                String    @id @default(cuid())
  userId            String    @unique
  firstName         String?
  lastName          String?
  dateOfBirth       DateTime?
  nationality       String?
  countryOfResidence String?
  
  educationLevel    String?
  gpa               Float?
  fieldsOfInterest  String[]
  targetCountries   String[]
  budgetRange       Json?
  
  fieldOfStudy      String?
  targetFields      String[]
  scholarshipTypes  String[]
  skills            String[]
  languages         String[]
  achievements      String[]
  volunteerWork     Json?
  careerGoal        String?
  interests         String[]
  researchAreas     String[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Scholarship {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.Text
  provider          String
  providerType      String
  scholarshipType   String
  
  country           String?
  continent         String?
  universityCountry String?
  
  eligibilityRules  Json?
  targetFields      String[]
  targetNationalities String[]
  targetCountries   String[]
  educationLevels   String[]
  
  amountMin         Int?
  amountMax         Int?
  amountCurrency    String    @default("USD")
  
  applicationDeadline DateTime?
  decisionDate      DateTime?
  notificationDate  DateTime?
  
  applicationURL    String?
  applicationFee    Int?
  requiredDocuments String[]
  essayPrompt       String?   @db.Text
  
  requirements      Json?
  tags              String[]
  isVerified        Boolean   @default(false)
  lastVerifiedAt    DateTime?
  verifiedBy        String?
  verifiedByUser    User?     @relation("VerifiedScholarships", fields: [verifiedBy], references: [id])
  source            String
  viewCount         Int       @default(0)
  matchCount        Int       @default(0)
  
  createdBy         String?
  createdByUser     User?     @relation("UserScholarships", fields: [createdBy], references: [id])
  favoritedBy       Favorite[]

  // ✅ KEEP THIS FIELD - DON'T REMOVE
  recentlyPosted    Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([provider])
  @@index([applicationDeadline])
  @@index([scholarshipType])
  @@index([isVerified])
  @@index([deletedAt])
  @@index([tags])
  @@index([country])
  @@index([continent])
  @@index([universityCountry])
}

model Favorite {
  id              String    @id @default(cuid())
  userId          String
  scholarshipId   String
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarship     Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([userId, scholarshipId])
  @@index([userId])
  @@index([scholarshipId])
}

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planType          PlanType  @default(FREE)
  planFeatures      Json?
  
  status            SubscriptionStatus @default(ACTIVE)
  
  amount            Int?
  currency          String    @default("USD")
  interval          String?
  trialEndsAt       DateTime?
  
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt        DateTime?
  pausedAt          DateTime?
  
  stripeSubscriptionId String? @unique
  stripeCustomerId    String?
  chapaTransactionId  String?  @unique
  
  cancellationReason String?
  retentionAttempts  Int       @default(0)
  
  transactions      Transaction[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([userId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([planType])
}

enum PlanType {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
  TRIAL
  EXPIRED
}

model Transaction {
  id                String    @id @default(cuid())
  
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])
  
  subscriptionId    String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  
  amountUSD         Int?
  amountETB         Int?
  exchangeRate      Float?
  
  provider          PaymentProvider
  providerTransactionId String?
  providerStatus    String?
  
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  
  idempotencyKey    String    @unique
  
  metadata          Json?
  failureReason     String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([provider])
  @@index([providerTransactionId])
  @@index([idempotencyKey])
}

enum PaymentProvider {
  STRIPE
  CHAPA
}

enum TransactionType {
  SUBSCRIPTION_CREATE
  SUBSCRIPTION_RENEW
  SUBSCRIPTION_UPGRADE
  SUBSCRIPTION_DOWNGRADE
  REFUND
  PAYMENT_FAILURE
  RETRY
  MANUAL
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}