generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  uid           String    @unique
  email         String    @unique
  emailVerified Boolean   @default(false)
  displayName   String?
  photoURL      String?
  role          String    @default("VIEWER") // "VIEWER", "EMPLOYEE", "ADMIN"
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  profile       Profile?
  scholarships  Scholarship[] @relation("UserScholarships")
  favorites     Favorite[]
  verifiedScholarships Scholarship[] @relation("VerifiedScholarships")

  @@index([uid])
  @@index([email])
  @@index([deletedAt])
  @@index([role])
}

model Profile {
  id                String    @id @default(cuid())
  userId            String    @unique
  firstName         String?
  lastName          String?
  dateOfBirth       DateTime?
  nationality       String?
  countryOfResidence String?
  
  // ✅ EXISTING FIELDS - KEEP AS IS
  educationLevel    String?   // HIGH_SCHOOL, BACHELORS, MASTERS, PHD
  gpa               Float?
  fieldsOfInterest  String[]
  targetCountries   String[]
  budgetRange       Json?
  
  // 🆕 NEW FIELDS - SAFE TO ADD (optional, nullable)
  fieldOfStudy      String?
  targetFields      String[]
  scholarshipTypes  String[]
  skills            String[]
  languages         String[]
  achievements      String[]
  volunteerWork     Json?
  careerGoal        String?
  interests         String[]
  researchAreas     String[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Scholarship {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.Text
  provider          String
  providerType      String
  scholarshipType   String
  
  // ✅ EXISTING FIELDS - KEEP AS IS
  eligibilityRules  Json?
  targetFields      String[]
  targetNationalities String[]
  targetCountries   String[]
  educationLevels   String[]
  
  amountMin         Int?
  amountMax         Int?
  amountCurrency    String    @default("USD")
  
  applicationDeadline DateTime?
  decisionDate      DateTime?
  notificationDate  DateTime?
  
  applicationURL    String?
  applicationFee    Int?
  requiredDocuments String[]
  essayPrompt       String?   @db.Text
  
  tags              String[]
  isVerified        Boolean   @default(false)
  lastVerifiedAt    DateTime?
  verifiedBy        String?
  verifiedByUser    User?     @relation("VerifiedScholarships", fields: [verifiedBy], references: [id])
  source            String
  viewCount         Int       @default(0)
  matchCount        Int       @default(0)
  
  createdBy         String?
  createdByUser     User?     @relation("UserScholarships", fields: [createdBy], references: [id])
  favoritedBy       Favorite[]

  // 🆕 NEW FIELDS - SAFE TO ADD (optional, nullable)
  country           String?   // Scholarship country
  continent         String?   // US, EUROPE, ASIA, UK, AUSTRALIA, AFRICA, OTHER
  universityCountry String?   // Country where you can study
  requirements      Json?     // English proficiency, GPA, work experience, etc.
  recentlyPosted    Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // ✅ EXISTING INDEXES - KEEP AS IS
  @@index([provider])
  @@index([applicationDeadline])
  @@index([scholarshipType])
  @@index([isVerified])
  @@index([deletedAt])
  @@index([tags])
  
  // 🆕 NEW INDEXES - SAFE TO ADD
  @@index([country])
  @@index([continent])
  @@index([universityCountry])
}

model Favorite {
  id              String    @id @default(cuid())
  userId          String
  scholarshipId   String
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarship     Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([userId, scholarshipId])
  @@index([userId])
  @@index([scholarshipId])
}