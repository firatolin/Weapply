generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  uid           String    @unique
  email         String    @unique
  emailVerified Boolean   @default(false)
  displayName   String?
  photoURL      String?
  role          String    @default("VIEWER")
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  profile       Profile?
  scholarships  Scholarship[] @relation("UserScholarships")
  favorites     Favorite[]
  verifiedScholarships Scholarship[] @relation("VerifiedScholarships")
  
  // NEW: Relations for payments
  subscription  Subscription?
  transactions  Transaction[]

  @@index([uid])
  @@index([email])
  @@index([deletedAt])
  @@index([role])
}

model Profile {
  id                String    @id @default(cuid())
  userId            String    @unique
  firstName         String?
  lastName          String?
  dateOfBirth       DateTime?
  nationality       String?
  countryOfResidence String?
  
  educationLevel    String?
  gpa               Float?
  fieldsOfInterest  String[]
  targetCountries   String[]
  budgetRange       Json?
  
  fieldOfStudy      String?
  targetFields      String[]
  scholarshipTypes  String[]
  skills            String[]
  languages         String[]
  achievements      String[]
  volunteerWork     Json?
  careerGoal        String?
  interests         String[]
  researchAreas     String[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Scholarship {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.Text
  provider          String
  providerType      String
  scholarshipType   String
  
  country           String?
  continent         String?
  universityCountry String?
  
  eligibilityRules  Json?
  targetFields      String[]
  targetNationalities String[]
  targetCountries   String[]
  educationLevels   String[]
  
  amountMin         Int?
  amountMax         Int?
  amountCurrency    String    @default("USD")
  
  applicationDeadline DateTime?
  decisionDate      DateTime?
  notificationDate  DateTime?
  
  applicationURL    String?
  applicationFee    Int?
  requiredDocuments String[]
  essayPrompt       String?   @db.Text
  
  requirements      Json?
  tags              String[]
  isVerified        Boolean   @default(false)
  lastVerifiedAt    DateTime?
  verifiedBy        String?
  verifiedByUser    User?     @relation("VerifiedScholarships", fields: [verifiedBy], references: [id])
  source            String
  viewCount         Int       @default(0)
  matchCount        Int       @default(0)
  
  createdBy         String?
  createdByUser     User?     @relation("UserScholarships", fields: [createdBy], references: [id])
  favoritedBy       Favorite[]

  // ✅ KEEP THIS FIELD - DON'T REMOVE
  recentlyPosted    Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([provider])
  @@index([applicationDeadline])
  @@index([scholarshipType])
  @@index([isVerified])
  @@index([deletedAt])
  @@index([tags])
  @@index([country])
  @@index([continent])
  @@index([universityCountry])
}

model Favorite {
  id              String    @id @default(cuid())
  userId          String
  scholarshipId   String
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarship     Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([userId, scholarshipId])
  @@index([userId])
  @@index([scholarshipId])
}

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planType          PlanType  @default(FREE)
  planFeatures      Json?
  
  status            SubscriptionStatus @default(ACTIVE)
  
  amount            Int?
  currency          String    @default("USD")
  interval          String?
  trialEndsAt       DateTime?
  
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt        DateTime?
  pausedAt          DateTime?
  
  stripeSubscriptionId String? @unique
  stripeCustomerId    String?
  chapaTransactionId  String?  @unique
  
  cancellationReason String?
  retentionAttempts  Int       @default(0)
  
  transactions      Transaction[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([userId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([planType])
}

enum PlanType {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
  TRIAL
  EXPIRED
}

model Transaction {
  id                String    @id @default(cuid())
  
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])
  
  subscriptionId    String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  
  amountUSD         Int?
  amountETB         Int?
  exchangeRate      Float?
  
  provider          PaymentProvider
  providerTransactionId String?
  providerStatus    String?
  
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  
  idempotencyKey    String    @unique
  
  metadata          Json?
  failureReason     String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([provider])
  @@index([providerTransactionId])
  @@index([idempotencyKey])
}

enum PaymentProvider {
  STRIPE
  CHAPA
}

enum TransactionType {
  SUBSCRIPTION_CREATE
  SUBSCRIPTION_RENEW
  SUBSCRIPTION_UPGRADE
  SUBSCRIPTION_DOWNGRADE
  REFUND
  PAYMENT_FAILURE
  RETRY
  MANUAL
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}